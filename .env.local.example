# App
NEXT_PUBLIC_APP_URL=https://readystate.now

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Signing secret for the Clerk → /api/webhooks/clerk user sync webhook.
# Configure in Clerk dashboard → Webhooks → select endpoint → Signing Secret.
CLERK_WEBHOOK_SECRET=
# Custom sign-in/up routes. Point Clerk at the branded pages we host
# ourselves instead of Clerk's hosted accounts.dev pages.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Vercel cron — required for /api/cron/* endpoints to accept requests.
# Vercel automatically injects this into the cron invocation.
CRON_SECRET=
