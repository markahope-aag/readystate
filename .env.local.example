# App
NEXT_PUBLIC_APP_URL=https://readystate.now

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Resend — used by the thank-you page to email PDF reports.
# Required. Sign up at https://resend.com and create an API key.
RESEND_API_KEY=
# Optional — override the sender address. Defaults to
# "ReadyState <reports@readystate.now>". The sending domain must be
# verified with Resend (DNS records they provide) before real mail
# will deliver.
RESEND_FROM_EMAIL=

# Vercel cron — required for /api/cron/* endpoints to accept requests.
# Vercel automatically injects this into the cron invocation.
CRON_SECRET=
